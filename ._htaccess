Options -Indexes
ServerSignature Off

# Bezpečnostní hlavičky
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
</IfModule>

# Zamezit přístupu ke konfiguračním souborům
<FilesMatch "\.(sql|md|log|ini|env)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# PHP nastavení
<IfModule mod_php8.c>
  php_flag display_errors Off
  php_flag log_errors On
  php_value error_log /tmp/svj_errors.log
  php_value session.cookie_httponly 1
  php_value session.cookie_samesite Strict
</IfModule>

# Gzip komprese
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
